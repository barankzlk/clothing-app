# Supabase — project URL and keys (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key (https://console.anthropic.com/) — used by
# /api/suggestions (small "what about a half-zip pullover?" idea prompts)
# and by /api/search to turn a query into an optimized German search term.
ANTHROPIC_API_KEY=

# SerpAPI key (https://serpapi.com/manage-api-key) — powers /api/search,
# which runs one Google Shopping lookup per shop.
SERPAPI_KEY=

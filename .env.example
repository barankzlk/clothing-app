# Supabase — project URL and keys (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key (https://console.anthropic.com/) — used only by
# /api/suggestions (small "what about a half-zip pullover?" idea prompts).
# Search itself does not call this.
ANTHROPIC_API_KEY=
